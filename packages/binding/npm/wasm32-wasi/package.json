{
  "name": "@open-spaced-repetition/binding-wasm32-wasi",
  "version": "0.2.1",
  "cpu": [
    "wasm32"
  ],
  "main": "fsrs-binding.wasi.cjs",
  "exports": {
    ".": {
      "browser": "./fsrs-binding.wasi-browser.js",
      "require": "./fsrs-binding.wasi.cjs",
      "default": "./fsrs-binding.wasi.cjs"
    },
    "./wasi-worker-browser.mjs": "./wasi-worker-browser.mjs",
    "./wasi-worker.mjs": "./wasi-worker.mjs",
    "./fsrs-binding.wasm32-wasi.wasm": "./fsrs-binding.wasm32-wasi.wasm",
    "./wasi-worker": {
      "browser": "./wasi-worker-browser.mjs",
      "default": "./wasi-worker.mjs"
    },
    "./wasm": "./fsrs-binding.wasm32-wasi.wasm"
  },
  "files": [
    "fsrs-binding.wasm32-wasi.wasm",
    "fsrs-binding.wasi.cjs",
    "fsrs-binding.wasi-browser.js",
    "wasi-worker.mjs",
    "wasi-worker-browser.mjs"
  ],
  "description": "Node.js bindings for the FSRS Optimizer implemented in Rust and compiled to WASI.",
  "keywords": [
    "napi-rs",
    "NAPI",
    "N-API",
    "Rust",
    "node-addon",
    "node-addon-api"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-spaced-repetition/ts-fsrs.git",
    "directory": "packages/binding"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "browser": "fsrs-binding.wasi-browser.js",
  "dependencies": {
    "@napi-rs/wasm-runtime": "^1.1.1",
    "@emnapi/core": "^1.9.0",
    "@emnapi/runtime": "^1.9.0"
  }
}
